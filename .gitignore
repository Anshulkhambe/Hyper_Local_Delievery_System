# Root .gitignore for HLMD FleetOpt

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.bak
*~

# OS Files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Eclipse Metadata and Settings
.metadata/
.recommenders/
backend/.metadata/
backend/.settings/
backend/.classpath
backend/.project
backend/.factorypath

# Build and Target Directories
backend/target/
target/
**/target/

# Node/React Dependencies and Build
node_modules/
frontend/node_modules/
frontend/dist/
dist/

# Env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
